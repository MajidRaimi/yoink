{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yoink",
  "version": "0.1.5",
  "identifier": "codes.yoink.desktop",
  "build": {
    "beforeDevCommand": "bun run scripts/build-sidecar.ts host && bun run vite:dev",
    "beforeBuildCommand": "bun run scripts/build-sidecar.ts && bun run vite:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "panel",
        "title": "Yoink",
        "width": 380,
        "height": 520,
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "windowEffects": {
          "effects": [
            "hudWindow"
          ],
          "state": "active",
          "radius": 14
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "category": "DeveloperTool",
    "externalBin": [
      "binaries/yoink"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "./Entitlements.plist",
      "dmg": {
        "background": "./dmg/background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 200 },
        "applicationFolderPosition": { "x": 480, "y": 200 }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQyMjY0NERCREUzNDY3NjgKUldSb1p6VGUyMFFtMHVxdnAreXMvRjlLQmpDWEZTV2UvcGozaFdIYmhLTzVoNXBQMGVrTHZEbFIK",
      "endpoints": [
        "https://github.com/MajidRaimi/yoink/releases/download/desktop-latest/latest.json"
      ]
    }
  }
}
